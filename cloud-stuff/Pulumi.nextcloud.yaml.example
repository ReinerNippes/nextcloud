# ╔════════════════════════════════════════════════════════════════════════╗
# ║  Nextcloud Wizard — Example Stack Configuration                      ║
# ║                                                                      ║
# ║  Copy this file:                                                     ║
# ║    cp Pulumi.nextcloud.yaml.example Pulumi.<stackname>.yaml          ║
# ║                                                                      ║
# ║  Two example combos are shown below.  Un-/comment as needed.         ║
# ╚════════════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────────────
# Example 1: Hetzner Compute + Hetzner DNS
# ──────────────────────────────────────────────────────────────────────────
config:
  # ── Provider selection ──────────────────────────────────────────────
  nextcloud-wizard:computeProvider: hetzner
  nextcloud-wizard:dnsProvider: hetzner

  # ── Hetzner Cloud credentials ──────────────────────────────────────
  hetzner:token:
    secure: v1:<your-hcloud-token>
  hetzner:sshKeyName: my-ssh-key         # existing key in Hetzner console
  hetzner:location: fsn1                 # fsn1 | nbg1 | hel1 | ash | hil

  # ── Hetzner DNS credentials ───────────────────────────────────────
  hetznerDns:token:
    secure: v1:<your-hetzner-dns-token>
  # hetznerDns:zoneId: abc123            # optional — auto-detected from zoneName

  # ── Common settings ───────────────────────────────────────────────
  nextcloud-wizard:sshPubKey: ssh-ed25519 AAAA... you@host
  nextcloud-wizard:zoneName: example.com
  nextcloud-wizard:environment: production
  nextcloud-wizard:image: debian-13            # default OS for all servers

  # ── Servers ────────────────────────────────────────────────────────
  nextcloud-wizard:servers:
    - name: nextcloud
      server_type: cx32
      networks:
        - public
      server_groups:
        - nextcloud
        - redis
        - database
        - webserver
        - docker
      public_firewall_rules:
        - ssh
        - letsencrypt
        - nextcloud
    - name: turn
      server_type: cx22
      networks:
        - public
      server_groups:
        - coturn
      public_firewall_rules:
        - ssh
        - letsencrypt
        - coturn
    - name: signal
      server_type: cx22
      networks:
        - public
      server_groups:
        - signal
      public_firewall_rules:
        - ssh
        - letsencrypt
        - signal
      # Additional named FQDNs for virtual hosts / extra certs.
      # Short names automatically get ".<zoneName>" appended.
      additional_fqdn_recording: rec
      # Alternative map syntax (equivalent):
      # additional_fqdns:
      #   recording: rec
      #   onlyoffice: office

  # ── Private network (optional) ────────────────────────────────────
  # nextcloud-wizard:network:
  #   name: nextcloud-net
  #   ip_range: 10.0.0.0/16
  #   subnet: 10.0.1.0/24

  # ── Network policies (TODO — not yet implemented) ─────────────────
  # Private-network firewall rules with source restrictions.
  # Will be translated to provider-native mechanisms where available
  # (AWS Security Groups, Scaleway private rules) or OS-level nftables
  # (Hetzner, which has no private-network firewalls).
  #
  # nextcloud-wizard:network_policies:
  #   - rule: database
  #     allow_from: [nextcloud]       # only servers in group "nextcloud"
  #     interface: private
  #   - rule: redis
  #     allow_from: [nextcloud]
  #     interface: private

