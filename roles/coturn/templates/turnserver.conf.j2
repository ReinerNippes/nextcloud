# TURN server configuration for Nextcloud Talk
# Generated by Ansible
# Do not edit this file directly!
#
listening-port=3478
tls-listening-port={{ coturn_tls_port }}
listening-ip={{ ansible_facts['default_ipv4']['address'] }}
relay-ip={{ external_ip.ansible_facts.ipify_public_ip }}
min-port=32769
max-port=65535
verbose
fingerprint
use-auth-secret
static-auth-secret={{ passwords.coturn }}
realm={{ ansible_facts['fqdn'] }}
cert={{ tls_certificate_file }}
pkey={{ tls_certificate_key }}
cipher-list="ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384"
dh-file={{ tls_certificate_directory }}/dhparam.pem
# syslog
keep-address-family
no-cli
no-tlsv1
no-tlsv1_1
# no-loopback-peers
no-multicast-peers
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
