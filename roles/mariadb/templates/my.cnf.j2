[client]
default-character-set = utf8mb4

[mysqld_safe]

[mysqld]
skip-name-resolve
{% if groups['database'][0] != groups['nextcloud'][0] %}
# Dedicated DB server: listen on all interfaces so Nextcloud can connect via TCP
bind-address              = 0.0.0.0
port                      = 3306
{% else %}
# Collocated DB server: disable TCP, Nextcloud connects via Unix socket only
skip-networking
{% endif %}

# connect_timeout         = 5
# wait_timeout            = 600
# max_allowed_packet      = 16M
# bulk_insert_buffer_size = 16M

# myisam_recover_options  = BACKUP
# open-files-limit        = 2000
# myisam_sort_buffer_size = 512M
# concurrent_insert       = 2
# read_buffer_size        = 2M
# read_rnd_buffer_size    = 1M

query_cache_limit         = 2M
# query_cache_size        = 64M
query_cache_type          = DEMAND

# query_cache_min_res_unit = 2k

# log_warnings            = 2
# slow_query_log_file     = /var/log/mysql/mariadb-slow.log
long_query_time           = 1
# log_slow_verbosity      = query_plan
# slow-query-log          = 1
# slow-query-log-file     = /var/log/mysql/slow.log
# log_bin                 = /var/log/mysql/mariadb-bin
# log_bin_index           = /var/log/mysql/mariadb-bin.index
# expire_logs_days        = 10
# max_binlog_size         = 100M

default_storage_engine         = InnoDB
innodb_large_prefix            = true
innodb_file_format             = barracuda
innodb_file_per_table          = 1

# Tuning parameters from group_vars/all/database.yml (mariadb_tuning_parameters)
{% for key, value in (mariadb_tuning_parameters | default({})).items() %}
{{ '%-30s' | format(key) }} = {{ value }}
{% endfor %}

character-set-server           = utf8mb4
collation-server               = utf8mb4_general_ci
transaction_isolation          = READ-COMMITTED
binlog_format                  = ROW

[mysqldump]
quick
quote-names
max_allowed_packet = 16M

[mysql]
#no-auto-rehash    # faster start of mysql but no tab completion

[isamchk]
key_buffer = 16M

