---

- name: Collect PHP-FPM RSS sizes
  ansible.builtin.command: "ps -o rss= -C {{ php_fpm_process_name[ansible_facts['os_family']] }}"
  register: fpm_sizes_raw
  changed_when: false

- name: Convert sizes to list of integers
  ansible.builtin.set_fact:
    fpm_sizes: "{{ fpm_sizes_raw.stdout_lines | map('int') | list }}"

- name: Fail if no FPM processes found
  when: fpm_sizes | length == 0
  ansible.builtin.fail:
    msg: "Keine PHP-FPM-Prozesse gefunden. Prüfe php_fpm_process_name={{ php_fpm_process_name }}"

- name: Calculate statistics
  ansible.builtin.set_fact:
    fpm_stats:
      count: "{{ fpm_sizes | length }}"
      min: "{{ fpm_sizes | min }}"
      max: "{{ fpm_sizes | max }}"
      avg: "{{ (fpm_sizes | sum / (fpm_sizes | length)) | round(0) }}"

- name: Set php_ram_kb
  set_fact:
    php_ram_kb: "{{ php_reserved_ram_mb * 1024 }}"

- name: Calculate recommended max_children
  set_fact:
    fpm_max_children: "{{ (php_ram_kb / fpm_stats.avg) | round(0) }}"

- name: Read current php-fpm pool configuration
  ansible.builtin.slurp:
    src: "{{ php_www_conf[ansible_facts['os_family']] | dirname }}/nextcloud.conf"
  register: php_fpm_conf_raw

- name: Decode php-fpm config
  ansible.builtin.set_fact:
    php_fpm_conf: "{{ php_fpm_conf_raw.content | b64decode }}"

- name: Extract current pm settings
  ansible.builtin.set_fact:
    php_fpm_current:
      pm: "{{ php_fpm_conf | regex_search('^pm\\s*=\\s*(\\w+)', '\\1', multiline=True) }}"
      pm_max_children: "{{ php_fpm_conf | regex_search('^pm\\.max_children\\s*=\\s*(\\d+)', '\\1', multiline=True) }}"
      pm_start_servers: "{{ php_fpm_conf | regex_search('^pm\\.start_servers\\s*=\\s*(\\d+)', '\\1', multiline=True) }}"
      pm_min_spare_servers: "{{ php_fpm_conf | regex_search('^pm\\.min_spare_servers\\s*=\\s*(\\d+)', '\\1', multiline=True) }}"
      pm_max_spare_servers: "{{ php_fpm_conf | regex_search('^pm\\.max_spare_servers\\s*=\\s*(\\d+)', '\\1', multiline=True) }}"

- name: Display summary
  debug:
    msg: 
      - "📊 PHP-FPM analysis completed"
      - ""
      - "Number of processes: {{ fpm_stats.count }}"
      - "Minimum size:        {{ (fpm_stats.min / 1024) | round(1) }} MB"
      - "Maximum size:        {{ (fpm_stats.max / 1024) | round(1) }} MB"
      - "Average size:        {{ (fpm_stats.avg / 1024) | round(1) }} MB"
      - ""
      - "Current configuration (from {{ php_www_conf[ansible_facts['os_family']] | dirname }}/nextcloud.conf ):"
      - "  pm = {{ php_fpm_current.pm }}"
      - "  pm.max_children = {{ php_fpm_current.pm_max_children }}"
      - "  pm.start_servers = {{ php_fpm_current.pm_start_servers }}"
      - "  pm.min_spare_servers = {{ php_fpm_current.pm_min_spare_servers }}"
      - "  pm.max_spare_servers = {{ php_fpm_current.pm_max_spare_servers }}"
      - ""
      - "Recommended settings:"
      - "  pm = dynamic"
      - "  pm.max_children = {{ fpm_max_children }}"
      - "  pm.start_servers = {{ (fpm_max_children * 0.25) | round(0) | int }}"
      - "  pm.min_spare_servers = {{ (fpm_max_children * 0.25) | round(0) | int }}"
      - "  pm.max_spare_servers = {{ (fpm_max_children * 0.5) | round(0) | int }}"
      - ""
      - "Basis:"
      - "  Reserved RAM for PHP-FPM: {{ php_reserved_ram_mb }} MB"
      - "  Average process size: {{ (fpm_stats.avg / 1024) | round(1) }} MB"
      - ""
      - "To apply recommendations, set the variable php_tuning in group_vars/all/php.yml"
      - "and rerun the playbook."
